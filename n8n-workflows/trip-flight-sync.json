{
  "name": "Trip.com 機票訂單自動同步",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */6 * * *"
            }
          ]
        }
      },
      "name": "Every 6 hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "getAll",
        "filters": {
          "query": "from:trip.com subject:機票訂單確認郵件 is:unread"
        },
        "limit": 50
      },
      "name": "Gmail - Search Messages",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [450, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "name": "Loop Over Messages",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "get",
        "messageId": "={{ $json.id }}"
      },
      "name": "Gmail - Get Message",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [850, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// 找到「行程單.pdf」附件\nconst payload = $input.item.json.payload;\n\nfunction findPdfAttachment(parts) {\n  if (!parts) return null;\n  \n  for (const part of parts) {\n    if (part.filename && part.filename.includes('行程單') && part.filename.endsWith('.pdf')) {\n      return {\n        filename: part.filename,\n        attachmentId: part.body.attachmentId,\n        size: part.body.size\n      };\n    }\n    \n    if (part.parts) {\n      const found = findPdfAttachment(part.parts);\n      if (found) return found;\n    }\n  }\n  \n  return null;\n}\n\nconst attachment = findPdfAttachment(payload.parts);\n\nif (!attachment) {\n  throw new Error('找不到行程單.pdf 附件');\n}\n\nreturn {\n  json: {\n    messageId: $input.item.json.id,\n    attachmentId: attachment.attachmentId,\n    filename: attachment.filename\n  }\n};"
      },
      "name": "Find PDF Attachment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "resource": "attachment",
        "operation": "get",
        "messageId": "={{ $json.messageId }}",
        "attachmentId": "={{ $json.attachmentId }}"
      },
      "name": "Gmail - Download PDF",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [1250, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "command": "python3",
        "arguments": "/Users/tokichin/Projects/venturo-erp/scripts/trip-flight-parser-n8n.py --pdf-base64 {{ $json.data }}",
        "options": {}
      },
      "name": "Parse PDF",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1450, 300]
    },
    {
      "parameters": {
        "functionCode": "// 解析 Python 輸出的 JSON\nconst output = $input.item.json.stdout;\nconst parsed = JSON.parse(output);\n\nif (parsed.error) {\n  throw new Error(parsed.error);\n}\n\nreturn { json: parsed };"
      },
      "name": "Parse JSON Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "YOUR_SPREADSHEET_ID_HERE"
        },
        "sheetName": "訂單列表",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "order_no": "={{ $json.order_no }}",
            "route": "={{ $json.route }}",
            "flight_no": "={{ $json.flight_no }}",
            "pnr": "={{ $json.pnr }}",
            "departure_date": "={{ $json.departure_date }}",
            "departure_time": "={{ $json.departure_time }}",
            "airline": "={{ $json.airline }}",
            "passengers": "={{ $json.passenger_names }}",
            "ticket_no": "={{ $json.segments[0].ticket_no || '' }}",
            "status": "已確認",
            "sync_time": "={{ $now.toISOString() }}"
          }
        },
        "options": {}
      },
      "name": "Google Sheets - Append Row",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [1850, 200],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "2",
          "name": "Google Sheets OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "addLabels",
        "messageId": "={{ $('Gmail - Get Message').item.json.id }}",
        "labelIds": [],
        "removeLabelIds": ["UNREAD"]
      },
      "name": "Gmail - Mark as Read",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [2050, 200],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2 account"
        }
      }
    },
    {
      "parameters": {
        "chatId": "@VENTURO_NEW_BOT",
        "text": "=🚨 Trip.com 訂單同步失敗\\n\\n訂單: {{ $json.order_no || '未知' }}\\n郵件 ID: {{ $('Gmail - Get Message').item.json.id }}\\n錯誤: {{ $json.error || $json.message }}\\n時間: {{ $now.format('YYYY-MM-DD HH:mm:ss') }}",
        "additionalFields": {}
      },
      "name": "Telegram - Error Notification",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1850, 400],
      "credentials": {
        "telegramApi": {
          "id": "3",
          "name": "Telegram Bot account"
        }
      }
    }
  ],
  "connections": {
    "Every 6 hours": {
      "main": [[{"node": "Gmail - Search Messages", "type": "main", "index": 0}]]
    },
    "Gmail - Search Messages": {
      "main": [[{"node": "Loop Over Messages", "type": "main", "index": 0}]]
    },
    "Loop Over Messages": {
      "main": [[{"node": "Gmail - Get Message", "type": "main", "index": 0}]]
    },
    "Gmail - Get Message": {
      "main": [[{"node": "Find PDF Attachment", "type": "main", "index": 0}]]
    },
    "Find PDF Attachment": {
      "main": [
        [{"node": "Gmail - Download PDF", "type": "main", "index": 0}],
        [{"node": "Telegram - Error Notification", "type": "main", "index": 0}]
      ]
    },
    "Gmail - Download PDF": {
      "main": [[{"node": "Parse PDF", "type": "main", "index": 0}]]
    },
    "Parse PDF": {
      "main": [[{"node": "Parse JSON Output", "type": "main", "index": 0}]]
    },
    "Parse JSON Output": {
      "main": [
        [{"node": "Google Sheets - Append Row", "type": "main", "index": 0}],
        [{"node": "Telegram - Error Notification", "type": "main", "index": 0}]
      ]
    },
    "Google Sheets - Append Row": {
      "main": [[{"node": "Gmail - Mark as Read", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
