<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>OpenClaw Installer</title>
    <options customize="never" require-scripts="false" hostArchitectures="x86_64,arm64"/>

    <!-- 歡迎畫面 -->
    <welcome file="welcome.html" mime-type="text/html"/>

    <!-- 完成畫面 -->
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <!-- 元件包參照 -->
    <pkg-ref id="com.venturo.openclaw-installer"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.venturo.openclaw-installer"/>
        </line>
    </choices-outline>

    <choice id="default"/>

    <choice id="com.venturo.openclaw-installer"
            visible="false"
            customLocation="/"
            title="OpenClaw">
        <pkg-ref id="com.venturo.openclaw-installer"/>
    </choice>

    <pkg-ref id="com.venturo.openclaw-installer"
             version="1.0.0"
             onConclusion="none">OpenClaw-Component.pkg</pkg-ref>
</installer-gui-script>
