#!/bin/bash
# ============================================================
# OpenClaw postinstall 腳本
# 此腳本在 macOS Installer 安裝過程中以 root 身分執行
# ============================================================

LOG_FILE="/tmp/openclaw-install.log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== OpenClaw 安裝開始 $(date) ==="

# ── 取得實際登入的使用者（不是 root）──
REAL_USER=$(stat -f "%Su" /dev/console)
REAL_HOME=$(eval echo "~$REAL_USER")

echo "安裝使用者: $REAL_USER"
echo "使用者目錄: $REAL_HOME"

# ── 輔助函式：以使用者身分執行 ──
run_as_user() {
  su - "$REAL_USER" -c "$1"
}

# ── 判斷 Homebrew 路徑 ──
if [[ $(uname -m) == "arm64" ]]; then
  BREW_PREFIX="/opt/homebrew"
else
  BREW_PREFIX="/usr/local"
fi
BREW="$BREW_PREFIX/bin/brew"

# ══════════════════════════════════════════
# Step 1: Homebrew
# ══════════════════════════════════════════
echo ""
echo "=== Step 1: Homebrew ==="

if [[ -x "$BREW" ]]; then
  echo "Homebrew 已安裝: $($BREW --version | head -1)"
else
  echo "正在安裝 Homebrew..."
  run_as_user 'NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'

  # Apple Silicon：確保 PATH 設定
  if [[ $(uname -m) == "arm64" ]]; then
    ZPROFILE="$REAL_HOME/.zprofile"
    if ! grep -q 'brew shellenv' "$ZPROFILE" 2>/dev/null; then
      echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> "$ZPROFILE"
      chown "$REAL_USER" "$ZPROFILE"
    fi
  fi

  if [[ -x "$BREW" ]]; then
    echo "Homebrew 安裝完成"
  else
    echo "ERROR: Homebrew 安裝失敗"
    exit 1
  fi
fi

# ══════════════════════════════════════════
# Step 2: Node.js 22
# ══════════════════════════════════════════
echo ""
echo "=== Step 2: Node.js 22 ==="

NODE_VERSION=$(run_as_user "$BREW_PREFIX/bin/node --version 2>/dev/null" | sed 's/v//')
NODE_MAJOR=$(echo "$NODE_VERSION" | cut -d. -f1)

if [[ "$NODE_MAJOR" -ge 22 ]] 2>/dev/null; then
  echo "Node.js 已安裝: v$NODE_VERSION"
else
  echo "正在安裝 Node.js 22..."
  run_as_user "$BREW install node@22"
  run_as_user "$BREW link --force --overwrite node@22 2>/dev/null || true"

  NEW_VERSION=$(run_as_user "$BREW_PREFIX/bin/node --version 2>/dev/null")
  if [[ -n "$NEW_VERSION" ]]; then
    echo "Node.js 安裝完成: $NEW_VERSION"
  else
    echo "ERROR: Node.js 安裝失敗"
    exit 1
  fi
fi

# ══════════════════════════════════════════
# Step 3: pnpm
# ══════════════════════════════════════════
echo ""
echo "=== Step 3: pnpm ==="

if run_as_user "command -v pnpm" &>/dev/null; then
  PNPM_VER=$(run_as_user "pnpm --version 2>/dev/null")
  echo "pnpm 已安裝: v$PNPM_VER"
else
  echo "正在安裝 pnpm..."
  run_as_user "npm install -g pnpm"

  if run_as_user "command -v pnpm" &>/dev/null; then
    echo "pnpm 安裝完成"
  else
    echo "WARNING: pnpm 安裝完成，重開終端機後生效"
  fi
fi

# ══════════════════════════════════════════
# Step 4: OpenClaw
# ══════════════════════════════════════════
echo ""
echo "=== Step 4: OpenClaw ==="

if run_as_user "command -v openclaw" &>/dev/null; then
  echo "OpenClaw 已安裝，正在更新..."
fi

echo "正在安裝 OpenClaw..."
run_as_user "pnpm install -g openclaw@latest 2>/dev/null || npm install -g openclaw@latest"

if run_as_user "command -v openclaw" &>/dev/null; then
  OC_VER=$(run_as_user "openclaw --version 2>/dev/null")
  echo "OpenClaw 安裝完成: $OC_VER"
else
  echo "ERROR: OpenClaw 安裝失敗"
  exit 1
fi

# ══════════════════════════════════════════
# Step 5: 開啟瀏覽器登入驗證
# ══════════════════════════════════════════
echo ""
echo "=== Step 5: 登入驗證 ==="

# 用 osascript 提示使用者，然後開啟瀏覽器登入
osascript -e '
  display dialog "安裝即將完成！

接下來會開啟瀏覽器，請用您的 Claude 訂閱帳號登入，完成驗證。" ¬
    with title "OpenClaw - 登入驗證" ¬
    with icon note ¬
    buttons {"開啟瀏覽器登入"} ¬
    default button "開啟瀏覽器登入"
' 2>/dev/null || true

# 以使用者身分開啟瀏覽器登入
run_as_user "open 'https://claude.ai/login'"
echo "已開啟瀏覽器登入頁面"

# ══════════════════════════════════════════
# 完成
# ══════════════════════════════════════════
echo ""
echo "=== 安裝完成 $(date) ==="
echo "記錄檔: $LOG_FILE"

exit 0
